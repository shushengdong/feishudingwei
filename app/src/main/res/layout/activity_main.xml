<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Location Mod"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Current GPS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Current"
            android:textSize="13sp"
            android:textColor="#666" />

        <TextView
            android:id="@+id/tv_current_coords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waiting..."
            android:textSize="13sp"
            android:textColor="#333" />
    </LinearLayout>

    <!-- Mock Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_mock_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Not started"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_stop_mock"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Stop"
            android:textSize="12sp"
            android:enabled="false"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btn_map_picker"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Map"
            android:textSize="12sp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Target App -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target:"
            android:textSize="13sp"
            android:textColor="#666"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_selected_app"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="None"
            android:textSize="13sp"
            android:textColor="#999" />

        <Button
            android:id="@+id/btn_select_app"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Select"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Capture + WiFi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btn_capture"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Capture"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btn_wifi_config"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="WiFi"
            android:layout_marginHorizontal="2dp" />

        <Button
            android:id="@+id/btn_guide"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Guide"
            android:layout_marginHorizontal="2dp" />

        <Button
            android:id="@+id/btn_diag"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Diag"
            android:layout_marginStart="2dp" />
    </LinearLayout>

    <!-- Diagnostic Summary (hidden by default) -->
    <LinearLayout
        android:id="@+id/ll_diag_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#FFF3E0"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_diag_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#E65100" />
    </LinearLayout>

    <!-- Environment Info Bar -->
    <LinearLayout
        android:id="@+id/ll_env_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:background="#E8F5E9"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_env_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#2E7D32" />
    </LinearLayout>

    <!-- Saved Locations Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Saved Locations"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_setup_guide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dev Options"
            android:textSize="11sp"
            android:textColor="#2196F3"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Location List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_locations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
