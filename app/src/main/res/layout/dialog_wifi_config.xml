<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 当前WiFi状态 -->
    <TextView
        android:id="@+id/tv_current_wifi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="正在获取当前WiFi..."
        android:textSize="12sp"
        android:textColor="#888"
        android:padding="8dp"
        android:background="#F5F5F5"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="WiFi SSID（名称）"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_wifi_ssid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="BSSID（MAC地址）"
        android:layout_marginTop="12dp"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_wifi_bssid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btn_capture_wifi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="捕获当前WiFi"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_gen_bssid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="随机生成BSSID"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="提示：连接WiFi后点击【捕获】自动获取当前WiFi信息，用于对抗打卡App的WiFi列表检测。未连接WiFi时可手动输入或随机生成。"
        android:textSize="11sp"
        android:textColor="#888"
        android:layout_marginTop="8dp" />

</LinearLayout>
