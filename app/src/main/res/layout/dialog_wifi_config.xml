<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- еҪ“еүҚWiFiзҠ¶жҖ?-->
    <TextView
        android:id="@+id/tv_current_wifi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="жӯЈеңЁиҺ·еҸ–еҪ“еүҚWiFi..."
        android:textSize="12sp"
        android:textColor="#888"
        android:padding="8dp"
        android:background="#F5F5F5"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="WiFi SSIDпјҲеҗҚз§°пјү"
        >

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_wifi_ssid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="BSSIDпјҲMACең°еқҖпј?
        android:layout_marginTop="12dp"
        >

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_wifi_bssid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btn_capture_wifi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="жҚ•иҺ·еҪ“еүҚWiFi"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_gen_bssid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="йҡҸжңәз”ҹжҲҗBSSID"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="жҸҗзӨәпјҡиҝһжҺҘWiFiеҗҺзӮ№еҮ»гҖҗжҚ•иҺ·гҖ‘иҮӘеҠЁиҺ·еҸ–еҪ“еүҚWiFiдҝЎжҒҜпјҢз”ЁдәҺеҜ№жҠ—жү“еҚЎAppзҡ„WiFiеҲ—иЎЁжЈҖжөӢгҖӮжңӘиҝһжҺҘWiFiж—¶еҸҜжүӢеҠЁиҫ“е…ҘжҲ–йҡҸжңәз”ҹжҲҗгҖ?
        android:textSize="11sp"
        android:textColor="#888"
        android:layout_marginTop="8dp" />

</LinearLayout>
